#! /usr/bin/env python

import os
from astropy.table import Table
from peewee import JOIN
import pandas as pd
from lvmsurveysim.schedule.opsdb import OpsDB
from sdssdb.peewee.lvmdb.lvmopsdb import (Observation, Tile, Dither,
                                          CompletionStatus, Version)

livedb = OpsDB.load_tiledb()
hist = OpsDB.load_history(tile_ids=livedb["tile_id"])
livedb.add_column(hist, name="history")
livedb.write("livedb.fits", format="fits", overwrite=True)

ver = Version.get(label=os.getenv("TILE_VER"))

hist = Tile.select(Tile.tile_id, Observation.jd,
                    Observation.lst, Observation.hz,
                    Observation.alt, Observation.lunation)\
            .join(Dither, JOIN.LEFT_OUTER)\
            .join(CompletionStatus, JOIN.LEFT_OUTER)\
            .switch(Dither)\
            .join(Observation, JOIN.LEFT_OUTER)\
            .where(Tile.version_pk == ver.pk,
                    CompletionStatus.done).dicts()

dataframe = pd.DataFrame(hist)

table = Table.from_pandas(dataframe)
table.write("history.fits", format="fits", overwrite=True)
